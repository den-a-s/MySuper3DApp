# Игнорирование файлов, создаваемых Visual Studio
.vs/
*.sln.docstates
*.suo
*.user
*.userosscache
*.sln.ide

# Игнорирование результатов сборки (Debug / Release и др.)
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Bb]in/
[Oo]bj/
*.exe
*.pdb
*.ilk
*.dll
*.lib
*.exp
*.idb
*.ipdb
*.iobj
*.tlog
*.lastbuildstate
*.manifest
*.log

# Игнорирование временных файлов и резервных копий
*.aps
*.tmp
*.temp
*.bak
*.old
*~

# Игнорирование файлов, создаваемых при компиляции шейдеров (если они генерируются)
*.cso
*.hlsli
*.pso

# Игнорирование файлов базы данных программ (IntelliSense)
*.ipch
*.db
*.opendb
*.VC.db
*.VC.opendb

# Игнорирование файлов, специфичных для DirectX (например, скомпилированные шейдеры, если они не нужны в репозитории)
# Раскомментируйте, если не хотите хранить скомпилированные шейдеры
# *.cso
# *.h

# Игнорирование папок с внешними зависимостями (например, vcpkg)
/vcpkg/
/packages/

# Игнорирование файлов, создаваемых редактором Visual Studio при отладке
*.sdf
*.opensdf
*.VC.opendb
*.VC.db

# Игнорирование файлов, создаваемых при работе с Git (если есть подмодули)
*.gitmodules